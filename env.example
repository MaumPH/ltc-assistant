# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: Optional Postgres connection string for pgvector-backed RAG storage.
# Example: postgres://postgres:postgres@localhost:5432/ltc_rag
DATABASE_URL="postgres://postgres:postgres@localhost:5432/ltc_rag"

# RAG_STORAGE_MODE: memory | postgres
# memory keeps the index in-process from the local knowledge folder.
# postgres expects the schema in db/rag-schema.sql and an indexed chunks table.
RAG_STORAGE_MODE="memory"

# VITE_RAG_API_BASE_URL: Optional absolute backend origin for the frontend build.
# Leave empty for same-origin local development.
VITE_RAG_API_BASE_URL=""

# RAG_FRONTEND_ORIGIN: Optional CORS allow-origin for a separately hosted frontend.
RAG_FRONTEND_ORIGIN=""
