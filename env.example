# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: Optional Postgres connection string for pgvector-backed RAG storage.
# Example: postgres://postgres:postgres@localhost:5432/ltc_rag
DATABASE_URL="postgres://postgres:postgres@localhost:5432/ltc_rag"

# RAG_STORAGE_MODE: memory | postgres
# memory keeps the index in-process from the local knowledge folder.
# postgres expects the schema in db/rag-schema.sql and an indexed chunks table.
RAG_STORAGE_MODE="memory"

# RAG_EMBEDDING_MAX_CHUNKS_PER_PASS: how many missing chunks to embed in a single pass.
# Lower this if you are on a tight Gemini quota and want the server to warm up gradually.
RAG_EMBEDDING_MAX_CHUNKS_PER_PASS="400"

# RAG_EMBEDDING_API_KEY: Optional dedicated Gemini key for document and query embeddings.
# If omitted, the server falls back to GEMINI_API_KEY for embeddings.
RAG_EMBEDDING_API_KEY=""

# RAG_GENERATION_MODE: user | server
# user means retrieval runs with the server embedding key, but final answer generation requires a user-provided key.
# server means the backend also generates answers with its own server-side key.
RAG_GENERATION_MODE="user"

# RAG_EMBEDDING_READY_THRESHOLD: readiness threshold for hybrid retrieval.
# 0 means any embedding coverage counts as hybrid partial, 1 means full coverage is required for hybrid ready.
RAG_EMBEDDING_READY_THRESHOLD="0.9"

# RAG_EMBEDDING_REFRESH_INTERVAL_MS: minimum wait before another background embedding pass.
RAG_EMBEDDING_REFRESH_INTERVAL_MS="900000"

# RAG_EMBEDDING_QUOTA_COOLDOWN_MS: pause further embedding attempts after a 429/quota error.
RAG_EMBEDDING_QUOTA_COOLDOWN_MS="21600000"

# VITE_RAG_API_BASE_URL: Optional absolute backend origin for the frontend build.
# Leave empty for same-origin local development.
VITE_RAG_API_BASE_URL=""

# RAG_FRONTEND_ORIGIN: Optional CORS allow-origin for a separately hosted frontend.
RAG_FRONTEND_ORIGIN=""
