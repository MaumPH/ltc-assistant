# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: Optional Postgres connection string for pgvector-backed RAG storage.
# Example: postgres://postgres:postgres@localhost:5432/ltc_rag
DATABASE_URL="postgres://postgres:postgres@localhost:5432/ltc_rag"

# RAG_STORAGE_MODE: memory | postgres
# memory keeps the index in-process from the local knowledge folder.
# postgres expects the schema in db/rag-schema.sql and an indexed chunks table.
RAG_STORAGE_MODE="memory"

# RAG_EMBEDDING_MAX_CHUNKS_PER_PASS: how many missing chunks to embed in a single pass.
# Lower this if you are on a tight Gemini quota and want the server to warm up gradually.
RAG_EMBEDDING_MAX_CHUNKS_PER_PASS="400"

# RAG_EMBEDDING_API_KEY: Optional dedicated Gemini key for document and query embeddings.
# If omitted, the server falls back to GEMINI_API_KEY for embeddings.
RAG_EMBEDDING_API_KEY=""

# RAG_GENERATION_MODE: user | server
# user means retrieval runs with the server embedding key, but final answer generation requires a user-provided key.
# server means the backend also generates answers with its own server-side key.
RAG_GENERATION_MODE="user"

# ADMIN_DASHBOARD_PASSWORD: Password required to open the administrator dashboard.
# Leave empty to disable admin dashboard access until a password is set.
ADMIN_DASHBOARD_PASSWORD=""

# ADMIN_DASHBOARD_SESSION_TTL_MS: How long an admin login token remains valid.
ADMIN_DASHBOARD_SESSION_TTL_MS="28800000"

# RAG_EMBEDDING_READY_THRESHOLD: readiness threshold for hybrid retrieval.
# 0 means any embedding coverage counts as hybrid partial, 1 means full coverage is required for hybrid ready.
RAG_EMBEDDING_READY_THRESHOLD="0.9"

# RAG_EMBEDDING_REFRESH_INTERVAL_MS: minimum wait before another background embedding pass.
RAG_EMBEDDING_REFRESH_INTERVAL_MS="900000"

# RAG_EMBEDDING_QUOTA_COOLDOWN_MS: pause further embedding attempts after a 429/quota error.
RAG_EMBEDDING_QUOTA_COOLDOWN_MS="21600000"

# LAW_MCP_ENABLED: enable selective Korean Law MCP fallback.
LAW_MCP_ENABLED="true"

# LAW_MCP_BASE_URL: stateless HTTP base URL for a Korean Law MCP sidecar.
# Example: http://127.0.0.1:3100
# LAW_OC belongs to the sidecar process only. Keep the API key out of the app server env when possible.
LAW_MCP_BASE_URL="http://127.0.0.1:3100"

# LAW_FALLBACK_CONFIDENCE_THRESHOLD: high | medium | low
# Fallback runs when retrieval confidence is at or below this threshold.
LAW_FALLBACK_CONFIDENCE_THRESHOLD="low"

# ONTOLOGY_GRAPH_DEPTH: graph expansion depth for ontology-driven boosts.
ONTOLOGY_GRAPH_DEPTH="1"

# VITE_RAG_API_BASE_URL: Optional absolute backend origin for the frontend build.
# Leave empty for same-origin local development.
VITE_RAG_API_BASE_URL=""

# RAG_FRONTEND_ORIGIN: Optional CORS allow-origin for a separately hosted frontend.
RAG_FRONTEND_ORIGIN=""

# RAG_CSP_CONNECT_SRC: Optional comma-separated extra connect-src origins for the production CSP header.
# Use this if the browser build needs to call a different API origin.
RAG_CSP_CONNECT_SRC=""

# RAG_RATE_LIMIT_WINDOW_MS: Shared rate-limit window for chat and retrieval inspect endpoints.
RAG_RATE_LIMIT_WINDOW_MS="60000"

# RAG_CHAT_RATE_LIMIT_MAX: Max /api/chat requests allowed per window per IP.
RAG_CHAT_RATE_LIMIT_MAX="20"

# RAG_INSPECT_RATE_LIMIT_MAX: Max /api/retrieval/inspect requests allowed per window per IP.
RAG_INSPECT_RATE_LIMIT_MAX="20"
