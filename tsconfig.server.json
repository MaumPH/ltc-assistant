{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "allowJs": true,
    "noImplicitAny": false,
    "noEmit": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "server.ts",
    "scripts",
    "src/lib/nodeKnowledge.ts",
    "src/lib/nodePrompts.ts",
    "src/lib/promptAssembly.ts",
    "src/lib/ragCore.ts"
  ]
}
